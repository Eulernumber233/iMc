// 手持物摆放 / 手臂参数 —— 独立于 item_registry.json（后者由 gen 脚本生成，会覆盖）。
// 由 HeldDisplayRegistry 加载，改完不用重编译即可微调手感。
//
// 坐标 / 单位约定：
//   t = 平移 [x,y,z]，r = 欧拉角(度) [绕X, 绕Y, 绕Z]，s = 均匀缩放。
//   矩阵顺序：T · Ry · Rx · Rz · S（与旧硬编码一致）。
//   first = 第一人称（相机空间：+X右 / +Y上 / -Z前）。
//   third = 第三人称 / 远程（挂右手骨骼「握持点」之后，自动跟随摆臂/挥手）。
//
// 解析优先级：items[id] > defaults[模型类型] > 内置预设。
{
    // ── 第一人称手臂本体（空手时显示的手臂 + 挥手动画参数）──
    "arm": {
        "offset": [ 0.24, -0.54, -0.1 ],
        "pitch": 122,
        "yaw": 18,
        "roll": -35,
        "scale": 0.7,
        "swing_duration": 0.28,
        "swing_pitch_amp": 55,
        "swing_roll_amp": 20,
        "swing_lift": 0.1
    },

    // ── 命名 TRS 档案（可被多个物品共享）──
    "profiles": {
        // 方块物品：立方体握在手里
        "block": {
            "first": {
                "t": [ 0.18, -0.165, -0.35 ],
                "r": [ -2.5, -5, 14 ],
                "s": 0.165
            },
            "third": {
                "t": [ 0, 0.025, 0.02 ],
                "r": [ 39.5, 0, 0 ],
                "s": 0.255
            }
        },
        // 扁平 2D 挤出图标（材料、食物等大多数物品）
        "flat": {
            "first": {
                "t": [ 0.55, -0.43, -1 ],
                "r": [ -3.5, -33, -7 ],
                "s": 0.775
            },
            "third": {
                "t": [ -0.02, 0.17, 0.115 ],
                "r": [ 32, 0, 0 ],
                "s": 0.495
            }
        },
        // 工具（剑/斧/镐等，斜握，握柄朝下）—— 供多把工具共用
        "tool": {
            "first": {
                "t": [ 0.58, -0.405, -0.885 ],
                "r": [ 11, 119.5, 41 ],
                "s": 0.785
            },
            "third": {
                "t": [ -0.01, 0.16, 0.28 ],
                "r": [ -0.5, -84, -20 ],
                "s": 0.735
            }
        },
        // 望远镜（独特模型）
        "spyglass": {
            "first": {
                "t": [ 0.09, 0.02, -0.25 ],
                "r": [ 192, -3, -27 ],
                "s": 0.405
            },
            "third": {
                "t": [ -0.015, 0.35, 0.48 ],
                "r": [ -128, 3, -2.5 ],
                "s": 0.835
            }
        },
        "stick": {
            "first": {
                "t": [ 0.55, -0.43, -1 ],
                "r": [ -3.5, -32.5, 69.5 ],
                "s": 0.855
            },
            "third": {
                "t": [ -0.015, 0.205, 0.14 ],
                "r": [ -7, -89.5, -3 ],
                "s": 0.435
            }
        },
        "torch": {
            "first": {
                "t": [ 0.675, -0.89, -1.05 ],
                "r": [ 11, -1.5, 13.5 ],
                "s": 1.175
            },
            "third": {
                "t": [ 0.03, -0.025, -0.055 ],
                "r": [ 0, -84.5, -39.5 ],
                "s": 0.825
            }
        }
    },

    // ── 按模型类型的默认档案（物品未在 items 里点名时用）──
    "defaults": {
        "extruded_2d": "flat",
        "block_cube": "block",
        "custom_model": "flat"
    },

    // ── 物品 id → 档案名 的显式覆盖（独特 / 共用都在这里点名）──
    "items": {
        "spyglass": "spyglass",
        // 多把工具共用 "tool" 档案（斜握）
        "diamond_sword": "tool",
        "iron_sword": "tool",
        // "diamond_axe": "tool",
        // "diamond_pickaxe": "tool"
        "stick": "stick",
        "torch": "torch",
        "redstone_torch": "torch"
    }
}
