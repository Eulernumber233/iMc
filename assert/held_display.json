// 手持物摆放 / 手臂参数 —— 独立于 item_registry.json（后者由 gen 脚本生成，会覆盖）。
// 由 HeldDisplayRegistry 加载，改完不用重编译即可微调手感。
//
// 坐标 / 单位约定：
//   t = 平移 [x,y,z]，r = 欧拉角(度) [绕X, 绕Y, 绕Z]，s = 均匀缩放。
//   矩阵顺序：T · Ry · Rx · Rz · S（与旧硬编码一致）。
//   first = 第一人称（相机空间：+X右 / +Y上 / -Z前）。
//   third = 第三人称 / 远程（挂右手骨骼「握持点」之后，自动跟随摆臂/挥手）。
//
// 解析优先级：items[id] > defaults[模型类型] > 内置预设。
{
  // ── 第一人称手臂本体（空手时显示的手臂 + 挥手动画参数）──
  "arm": {
    "offset": [0.24, -0.54, -0.1],
    "pitch": 118.0,
    "yaw": 18.0,
    "roll": -35.0,
    "scale": 0.70,
    "swing_duration": 0.28,
    "swing_pitch_amp": 55.0,
    "swing_roll_amp": 20.0,
    "swing_lift": 0.10
  },

  // ── 命名 TRS 档案（可被多个物品共享）──
  "profiles": {
    // 方块物品：立方体握在手里
    "block": {
      "first": { "t": [0.55, -0.55, -1.0], "r": [25, 35, 0], "s": 0.55 },
      "third": { "t": [0.0, -0.06, 0.02], "r": [0, 0, 0], "s": 0.42 }
    },
    // 扁平 2D 挤出图标（材料、食物等大多数物品）
    "flat": {
      "first": { "t": [0.55, -0.55, -1.0], "r": [-10, 20, 0], "s": 0.70 },
      "third": { "t": [0.0, -0.14, 0.04], "r": [0, 0, 0], "s": 0.50 }
    },
    // 工具（剑/斧/镐等，斜握，握柄朝下）—— 供多把工具共用
    "tool": {
      "first": { "t": [0.50, -0.50, -0.90], "r": [0, 0, 45], "s": 0.85 },
      "third": { "t": [0.0, -0.16, 0.05], "r": [0, 0, 45], "s": 0.70 }
    },
    // 望远镜（独特模型）
    "spyglass": {
      "first": { "t": [0.42, -0.45, -0.85], "r": [5, -15, 0], "s": 0.65 },
      "third": { "t": [0.0, -0.20, 0.05], "r": [0, 0, 0], "s": 0.50 }
    }
  },

  // ── 按模型类型的默认档案（物品未在 items 里点名时用）──
  "defaults": {
    "extruded_2d": "flat",
    "block_cube": "block",
    "custom_model": "flat"
  },

  // ── 物品 id → 档案名 的显式覆盖（独特 / 共用都在这里点名）──
  "items": {
    "spyglass": "spyglass"
    // 例：多把工具共用 "tool" 档案（图标存在时取消注释即可）
    // "diamond_sword": "tool",
    // "iron_sword": "tool",
    // "diamond_axe": "tool",
    // "diamond_pickaxe": "tool"
  }
}
