{
    //--------------
    // ── 渲染 ──────────────────────────────────────────
    "render_radius": 16,
    //   视野半径（chunk），实际加载 (2r+1)^2 个 chunk

    "vertical_cull_ratio": 0.5,
    //   下方 section 剔除比例：maxDownSections = render_radius × 此值
    //   例 8×0.5=4 → 相机所在 section 向下 4 个以外不渲染。0 或负值 = 不限制

    "anisotropy": 0,
    //   各向异性过滤等级（方块纹理）。去远处地形/飞行俯视时的闪烁的核心手段。
    //   0 = 取硬件最大（通常 16）；填具体值（如 4、8、16）则取 min(该值, 硬件最大)

    "shadow_blocker_samples": 8,
    //   PCSS blocker search 抽样数（估遮挡物平均深度）。单帧少样本靠时域累积 + TAA 降噪
    "shadow_filter_samples": 8,
    //   PCSS PCF filter 抽样数（半影内可见度平均）。可降到 4 看时域累积后是否仍干净
    "shadow_light_size": 0.008,
    //   光源"大小"（阴影贴图 UV）。越大半影越宽（阴影越软），越小越硬

    "csm_cascade_count": 4,
    //   CSM 级联数（1~4，编译期上限 4）。近处高分辨率、远处低分辨率，根治远处阴影"波浪"
    "csm_split_lambda": 0.7,
    //   级联切分混合系数：1=纯对数（近处极密），0=纯均匀。偏大近处更密
    "csm_shadow_size": 2048,
    //   每级联分辨率（重建 target 才生效，改它需重启）。4 张 2048² ≈ 1 张 4096² 内存
    "shadow_max_distance": 180,
    //   阴影总覆盖距离（最远级联远边界，米）。每帧重算切分即生效，可热调

    "ao_directions": 4,
    //   HBAO 采样方向数。单帧少方向（噪声大）靠时域累积降噪。
    "ao_steps": 4,
    //   HBAO 每方向步进次数。同上，少步数 + 时域累积
    "ao_radius": 0.4,
    //   AO 采样半径（世界尺度，米）。约 1 方块。越大遮蔽范围越广
    "ao_intensity": 1.2,
    //   AO 强度（指数）。越大接触阴影越黑
    "ao_bias": 0.1,
    //   AO 切线角 bias（弧度）。抑制平坦表面的自遮挡暗带，过大会丢失接触阴影

    "ao_night_strength": 0.25,
    //   AO 随昼夜淡出的夜晚底值。白天 AO 全效，夜晚淡到此值（环境光弱而均匀，强 AO 违和）。
    //   0 = 夜晚完全无 AO；1 = 不淡出（AO 全程满强度，恢复旧行为）

    "light_budget": 1.25,
    //   总光照预算（整体亮度旋钮）。觉得整个画面偏暗就调大（如 1.4），偏亮调小
    "ambient_day": 0.55,
    //   白天环境光占比（未被阳光直射处的底光）。调大 → 阴影里/背阳面更亮
    "ambient_night": 0.40,
    //   夜晚环境光占比（夜间底光）。调大 → 夜里更亮
    "sun_strength": 0.70,
    //   阳光份额（正午满日照时的直射功率）。调大 → 受光面更亮、明暗对比更强
    //   近似能量守恒：ambient_day + sun_strength ≈ 1 时，正午完全受光面亮度约等于 light_budget

    "time_scale": 0.4,
    //   时间比例：1 现实秒 = 多少游戏小时。0.2 → 一整天(24h)约 120 现实秒。
    //   o/p 键运行时可调（可负=时间倒流），此处是启动初值



    //--------------
    // ── 多线程 ────────────────────────────────────────
    "worker_threads": 2,
    //   0 = 自动（hardware_concurrency）；正数 = 指定线程数

    "max_inflight_requests": 32,
    //   同时投递的最大 build 任务数，超过则暂停请求新 chunk



    //--------------
    // ── GPU 上传 ──────────────────────────────────────
    "max_uploads_per_frame": 16,
    //   每帧最多上传多少个脏 section 到 GPU arena



    //--------------
    // ── 存档 ──────────────────────────────────────────
    "auto_save_interval_sec": 60,
    //   自动保存间隔（秒）；设为 0 禁用定时自动保存，区块卸载时仍会保存

    "retain_margin_chunks": 6,
    //   温存/落盘半径余量：chunk 离开渲染半径后，在 render_radius + 此值 内仍保留在内存
    //   （不渲染、不卸载、不落盘），吸收边界来回走动的抖动；超出才落盘 + 卸载。
    //   调大 = 更省磁盘 IO 与地形重生成，但占更多内存



    //--------------
    // ── 调试 ──────────────────────────────────────────
    "print_profile_every_second": false,
    //   每秒打印一次 profiler 汇总（各函数耗时 + 频道指标）
    //   验证网络线程化阶段 2：原地静止跑 Host+Join，看主线程 net.* 各段【毫秒数】——
    //   net.dispatch/net.pushChunks/net.pollSerialize/net.propSync 应都趋近 0（dispatch 除外，
    //   它含 chunk 导入）。FPS 在单机多开下被 GPU 争抢污染，不可作为网络开销的判据，只看 CPU ms。

    "profile_detailed": false,
    //   细粒度计时/计数开关：关闭时（默认）完全绕过热路径里的细分插桩
    //   （cullPass 每 chunk 的 rdc.cull.* 计时、getVisibleSectionMask 每 section 的 vis.*
    //   计数），连 steady_clock::now() 都不调，零开销。仅排查 cullPass 内部分布时才开。

    "verbose_texture_loading": false,
    //   输出纹理加载详情日志（每次启动时输出纹理加载信息，可关闭以减少干扰）

    "verbose_shader_loading": false,
    //   输出着色器编译日志（编译成功/失败消息，可关闭以减少干扰）

    "force_recompile_shaders": false,
    //   强制重新编译着色器：true 则忽略并删除磁盘缓存(cache/shaders/*.bin)，从源码重编后
    //   重写缓存。改了着色器源码后置 true 跑一次即可（缓存键只哈希文件名、不哈希内容）。
    //   命令行 --rebuild-shaders / --no-rebuild-shaders 优先级高于此字段。

    "debug_mode": true
    //   调试模式：true 时物品注册表只加载标记 load_in_debug 的物品图标，
    //   避免每次启动加载 assert/minecraft/textures/item 下全量 600+ 张图标。
    //   正式发布置 false 加载全量物品资源。
}











